# ============================================================
# catch_fish 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ---- 应用配置 ----
APP_NAME=catch_fish
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# ---- 服务端口 ----
API_HOST=0.0.0.0
API_PORT=8000

# ---- LLM 配置 (Anthropic Claude) ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-5-20251001
ANTHROPIC_MAX_TOKENS=4096

# ---- LLM 配置 (OpenAI 备用) ----
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ---- 数据库 (MySQL) ----
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=catch_fish
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=catch_fish
DATABASE_URL=mysql+pymysql://catch_fish:your_password_here@localhost:3306/catch_fish
DATABASE_URL_ASYNC=mysql+aiomysql://catch_fish:your_password_here@localhost:3306/catch_fish

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ---- 闲鱼认证 (Cookie方式) ----
XIANYU_COOKIE=
XIANYU_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# ---- 请求控制 ----
REQUEST_TIMEOUT=30
MAX_RETRIES=3
MAX_SEARCH_RESULTS=50
RATE_LIMIT_PER_MINUTE=20

# ---- 网页抓取代理 (可选) ----
SCRAPER_PROXY=http://proxy.example.com:8080
